# Один рабочий токен BattleMetrics. Второй/третий — только как резерв на
# случай 401/403 основного (истёк/отозван), НЕ для наращивания объёма запросов.
BATTLEMETRICS_TOKENS=your_bm_token_here

# Секрет, которым панель авторизуется перед этим сервисом (заголовок X-Relay-Secret).
RELAY_SHARED_SECRET=change_me_to_a_random_string

REDIS_URL=redis://127.0.0.1:6379/0

# Минимальный интервал между запросами к BattleMetrics, секунды.
BM_MIN_REQUEST_INTERVAL_SEC=1.0
# Запас перед лимитом (в запросах) — при остатке ниже ждём сброса окна.
BM_RATE_LIMIT_SAFETY_MARGIN=5
BM_DEFAULT_BACKOFF_SEC=5.0
BM_MAX_BACKOFF_SEC=300.0

# Желаемое окно обновления каждого отслеживаемого игрока, секунды.
# Реальный интервал = max(BM_MIN_REQUEST_INTERVAL_SEC, WATCH_REFRESH_WINDOW_SEC / кол-во_игроков).
WATCH_REFRESH_WINDOW_SEC=300
# Статус считается протухшим (is_stale=true в ответе), если не обновлялся дольше.
STATUS_STALE_AFTER_SEC=900

PORT=8000
